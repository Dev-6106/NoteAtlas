
# ============================================
# Frontend Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Backend API URL (your Railway deployment URL)
VITE_API_URL=https://your-backend.railway.app or http://localhost:8000

# Firebase Auth Configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google OAuth Client ID (from Google Cloud Console -> Credentials -> OAuth 2.0 Client IDs -> Web client)
VITE_GOOGLE_CLIENT_ID=

# Razor Pay
VITE_RAZORPAY_KEY_ID=