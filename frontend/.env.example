# ============================================
# Frontend Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Backend API URL (your Railway deployment URL)
VITE_API_URL=https://your-backend.railway.app

# Google OAuth / Drive Picker
# Same Client ID as used in backend Google OAuth
VITE_GOOGLE_CLIENT_ID=
# Google API Key (for Drive Picker) — get from Google Cloud Console
VITE_DEVELOPER_KEY=

# Stripe Publishable Key
# Get from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUB_KEY=pk_live_...