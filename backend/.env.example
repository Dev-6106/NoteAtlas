# ============================================
# Backend Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Application
NODE_ENV=production
PORT=8000
APP_URL=https://your-backend.railway.app
FRONTEND_URL=https://your-app.vercel.app

# Database (MongoDB Atlas recommended for production)
DB_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/notebooklm

# ─── LLM ────────────────────────────────────────────────
# Google Gemini (primary provider)
GOOGLE_GEMINI_API_KEY=

# Groq (optional fallback)
GROQ_API_KEY=

# ─── AI Services ────────────────────────────────────────
# Tavily (web search tool)
TAVILY_API_KEY=

# EXA Search (alternative web search)
EXA_SEARCH_API_KEY=

# Hugging Face (embeddings / optional)
HUGGINGFACE_API_KEY=

# Cohere (embeddings — required for RAG)
COHERE_API_KEY=

# ─── Vector Store ────────────────────────────────────────
# Pinecone (required for RAG document search)
PINECONE_API_KEY=
PINECONE_INDEX=notebooklm

# ─── Storage ────────────────────────────────────────────
# Supabase (file storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=Documents

# ─── Google OAuth 2.0 ───────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match exactly what you set in Google Console + point to your Railway domain
CALLBACK_URL=https://your-backend.railway.app/auth/google/callback
# After login, redirect back to frontend
SUCESS_REDIRECT_URL=https://your-app.vercel.app/auth/callback

# ─── Session / Cookie ───────────────────────────────────
# Generate with: openssl rand -hex 32
COOKIE_KEY=

# ─── JWT ────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ─── Payments (Stripe) ──────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Audio (ElevenLabs) ─────────────────────────────────
ELEVEN_LAB_API_KEY=
