# ============================================
# Backend Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Application
NODE_ENV=development
PORT=8000
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Database
DB_URL=mongodb://127.0.0.1:27017/notebooklm

# LLM Provider (Fireworks AI)
CHATFIREWORK_API_KEY=

# LangChain / Tavily (web search)
TAVILY_API_KEY=

# RAG - Embeddings (Cohere)
COHERE_API_KEY=

# RAG - Vector Store (Pinecone)
PINECONE_API_KEY=
PINECONE_INDEX=notebooklm

# Google OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
CALLBACK_URL=http://localhost:8000/auth/google/callback

# Session / Cookie
COOKIE_KEY=

# JWT Authentication
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
