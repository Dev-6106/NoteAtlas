{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node10",
    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "outDir": "dist",
    "rootDir": "src",

    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"]
    },

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    "ignoreDeprecations": "6.0"
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}