{
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",
    "moduleResolution": "node",

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "outDir": "dist",
    "rootDir": "src",

    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"]
    },

    "skipLibCheck": true
  },

  "include": [
    "src",
    "lessons/tools.js",
    "lessons/runnable.ts",
    "lessons/index.ts",
    "lessons/graph.ts",
    "added/briefing-doc.ts",
    "added/mindMap.ts",
    "added/study-guide.ts",
    "src/pipelines/summary.ts"
  ],

  "exclude": ["node_modules"]
}